{% extends "templates/index.html.jinja" %}
{% block main_content %}
  {% if summary %}
    <h2>Summary</h2>
    {% if file_name %}
      <h3>{{ file_name }}</h3>
    {% else %}
      <em><h3>Unknown File</h3></em>
    {% endif %}
    {% if file_size %}
      <h3> - {{ file_size }} bytes</h3>
    {% endif %}
    <br><pre>{{ summary }}</pre>
  {% else %}
    <h3>Unable to Generate Summary</h3>
  {% endif %}
{% endblock %}
