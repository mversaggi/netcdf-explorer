<!doctype html>
<html>
  <head>
    <title>NetCDF Explorer</title>
    <link rel="icon" href="{{ url_for('static', filename='blue-block_100x100.png') }}" type="image/png">
    <link rel="stylesheet" href="{{ url_for('static', filename='dist/output.css') }}">
  </head>
  <body class="min-h-full dark:bg-gray-900 dark:text-white">
    <div class="max-w-full items-center mx-auto mt-22 p-4 pt-8">
      <a href="localhost:5000" class="flex items-center space-x-3 rtl:space-x-reverse w-fit mx-auto">
          <img src="static/blue-block_100x100.png" class="h-12" alt="NetCDF Explorer Logo" />
          <span class="self-center text-4xl font-serif whitespace-nowrap">NetCDF Explorer</span>
      </a>
    </div>
    <div class="flex justify-center py-2 w-screen mt-13">
      <form method="POST" action="/" enctype="multipart/form-data" class="flex flex-col items-center w-1/2">
        <input class="w-full text-lg text-gray-900 border border-gray-300 rounded-lg cursor-pointer bg-gray-50 dark:text-gray-400 focus:outline-none dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark" id="file_input" type="file">
        <button type="button" class="m-10 text-white bg-blue-800 hover:bg-blue-800 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 dark:bg-blue-700 dark:hover:bg-blue-650 focus:outline-none dark:focus:ring-blue-800 cursor-pointer">Explore</button>
      </form>
      {% block main_content %}
        <div></div>
      {% endblock %}
    </div>
    <!-- TODO: Pull Flowbite from node_modules/ instead so that we can eventually dockerize the app -->
    <script src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
  </body>
</html>
